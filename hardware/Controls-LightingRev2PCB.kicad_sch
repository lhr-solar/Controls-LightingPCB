	(text "5V Logic \n\n"
		(exclude_from_sim no)
		(at 236.982 137.414 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0d13ce81-3b37-4cc9-a9e3-c4d5a49da71e")
	)
	(text "Ref1 anf Ref are connected together\nand also connected to a voltage \ndivider in order to provide a 0.1\nreference voltage instead of 0,\nwhen the output is disconnected."
		(exclude_from_sim no)
		(at 265.43 46.228 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1e47dfa9-4199-4b6d-aef3-86f525798743")
	)
	(text "Addressable Lights"
		(exclude_from_sim no)
		(at 240.03 19.304 0)
		(effects
			(font
				(size 5.08 5.08)
				(thickness 1.016)
				(bold yes)
			)
		)
		(uuid "28ca8ce7-1d0b-418e-9039-052364237738")
	)
	(text "THE WS2814 requires 5V \nbut the PSOM only \nsupplies 3.3V, hence the\nuse of a level shifter."
		(exclude_from_sim no)
		(at 227.33 156.21 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "45918f19-3cf1-4d83-a52e-4dbcae2a781a")
	)
	(text "3.3V Logic \n\n"
		(exclude_from_sim no)
		(at 198.628 137.414 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "85a77130-6b14-40d2-8e3f-23dd83683457")
	)
	(text "This unity gain butter is used \nto pretty much elimate current \ndraw and any voltage drops that\ncould occur from load.\n"
		(exclude_from_sim no)
		(at 152.146 98.298 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "85cdd919-68f7-4104-b555-ad8f4d0213e8")
	)
	(text "IC has a fixed gain of 200V\nMax input current = 1.24A\nVout @ max= 200v(1.24A)(0.012ohm) = 2.976 V\nPower = Imax^2(Rshunt) = (1.24)^2 (.012) = 0.0185 W"
		(exclude_from_sim no)
		(at 243.84 97.536 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c624fd1b-2282-4a39-a70f-a9eef6e608a4")
	)
	(text "0.1 - 3.2V output from negative\nfeedback loop\n"
		(exclude_from_sim no)
		(at 265.684 33.782 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c821a294-fe70-4054-8500-7f3c61b369be")
	)

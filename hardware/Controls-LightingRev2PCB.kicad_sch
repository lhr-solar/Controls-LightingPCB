	)
	(text "This unity gain butter is used \nto pretty much elimate current \ndraw and any voltage drops that\ncould occur from load.\n"
		(exclude_from_sim no)
		(at 73.406 109.474 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "85cdd919-68f7-4104-b555-ad8f4d0213e8")
	)
	(text "1 W/LED / 24V = 0.0417A/LED\n4 LEDs * 0.0417A/LED = 0.167A\n"
		(exclude_from_sim no)
		(at 78.994 188.722 0)
		(effects

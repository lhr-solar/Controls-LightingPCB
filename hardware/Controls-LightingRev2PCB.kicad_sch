	)
	(text "IC has a fixed gain of 200V\nMax input current = 1.24A\nVout @ max= 200v(1.24A)(0.012ohm) = 2.976 V\nPower = Imax^2(Rshunt) = (1.24)^2 (.012) = 0.0185 W"
		(exclude_from_sim no)
		(at 60.706 96.774 0)
		(effects

		(uuid "ba234b61-094b-4342-90af-0927fcd2c950")
	)
	(text "IC has a fixed gain of 200V\nMax input current = 1.24A\nVout @ max= 200v(1.24A)(0.012ohm) = 2.976 V\nPower = Imax^2(Rshunt) = (1.24)^2 (.012) = 0.0185 W"
		(exclude_from_sim no)
		(at 172.72 94.996 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c624fd1b-2282-4a39-a70f-a9eef6e608a4")
	)

	(text "THE WS2814 requires 5V \nbut the PSOM only \nsupplies 3.3V, hence the\nuse of a level shifter."
		(exclude_from_sim no)
		(at 198.882 157.226 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "45918f19-3cf1-4d83-a52e-4dbcae2a781a")
	)
	(text "(3.3k/103.3k) * (3.3V) = 0.1V\n3.006+0.1 = 3.106\n3.106<3.3V"
		(exclude_from_sim no)
		(at 97.028 140.97 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "45f2835b-3ecd-4e64-88a1-231d62458ba3")
	)

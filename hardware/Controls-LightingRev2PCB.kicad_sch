	(text "THE WS2814 requires 5V \nbut the PSOM onlys \nsupplies 3.3V, hence the\nuse of a level shifter."
		(exclude_from_sim no)
		(at 145.542 151.13 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "45918f19-3cf1-4d83-a52e-4dbcae2a781a")
	)
	(text "From my understanding, \nbidirectional diode is used \nto prevent voltage spikes \nand MOSFET is used to prevent\nreverse polarity."
		(exclude_from_sim no)
		(at 54.61 117.348 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4de870da-b348-469b-b0fc-8784b12a5674")
	)
	(text "Negative feedback loop to avoid infinite gain\n"
		(exclude_from_sim no)
		(at 215.9 20.574 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "533b37c8-6ef7-4602-83d7-426ba60ff46a")
	)
